{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "9.2.0",
  "description": "__MSG_extDescription__",
  "minimum_chrome_version": "114",
  "default_locale": "en",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "contextMenus",
    "downloads",
    "webRequest",
    "notifications",
    "alarms",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CDN / WAF Detector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open CDN/WAF Detector"
    },
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Open as side panel"
    },
    "scan-clipboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Scan domain from clipboard"
    }
  }
}